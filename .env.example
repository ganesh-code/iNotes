# =============================================================================
# iNotes — single root environment file
# Copy to `.env` in this directory (repo root):  cp .env.example .env
# =============================================================================

# --- Backend (Express API) ---
MONGO_URL=mongodb+srv://<username>:<url-encoded-password>@<cluster>/<dbname>?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_another_strong_secret
PORT=5500
NODE_ENV=development

# Frontend origin(s) for CORS — comma-separated in production
CLIENT_URL=http://localhost:3000

# Public API URL (used by React + logging). Same value as REACT_APP_API_URL in most setups.
API_URL=http://localhost:5500

# --- Client (React — REACT_APP_ prefix for build-time; also written to client/public/config.js) ---
REACT_APP_API_URL=http://localhost:5500

# --- AWS Secrets Manager (production — Elastic Beanstalk / CI) ---
# Store the same keys as JSON in Secrets Manager (see docs/AWS_SECRETS.md).
# USE_AWS_SECRETS=true
# AWS_SECRETS_MANAGER_SECRET_ID=inotes/production
# AWS_REGION=us-east-1

# --- Optional: scripts/mongodb-ping.js & scripts/mongodb-example.js ---
# If unset, those scripts use MONGO_URL above.
# MONGODB_URI=
